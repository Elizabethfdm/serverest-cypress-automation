    "cypress": "^15.18.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  }
}
